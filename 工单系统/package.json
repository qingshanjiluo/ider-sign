{
  "name": "ider-order-system",
  "version": "2.0.0",
  "description": "艾德尔修仙传 - 赛博朋克工单平台（Cloudflare Workers + D1）",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "init-db": "wrangler d1 execute ider-orders --file=./schema.sql",
    "preview-db": "wrangler d1 execute ider-orders --local --file=./schema.sql",
    "scan-orders": "node gh-actions/scan_orders.js",
    "health-check": "node gh-actions/health_check.js"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
